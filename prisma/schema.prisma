generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  emailVerified DateTime?
  name          String?
  image         String?
  role          String    @default("CUSTOMER")
  passwordHash  String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  pinHash            String?
  securityQuestion   String?
  securityAnswerHash String?

  stripeCustomerId   String?
  subscriptionId     String?
  plan               String  @default("STARTER")
  subscriptionStatus String  @default("inactive")

  accounts Account[]
  sessions Session[]
  business Business?
  customer Customer?
}

model Business {
  id              String   @id @default(cuid())
  userId          String   @unique
  name            String
  slug            String   @unique
  category        String
  address         String?
  phone           String?
  logoUrl         String?
  cardBgColor     String   @default("#1a1a2e")
  cardFgColor     String   @default("#ffffff")
  cardAccentColor String   @default("#e94560")
  cardLogoUrl     String?
  stampsRequired  Int      @default(10)
  rewardLabel     String   @default("Récompense offerte")
  pointsPerEuro   Float    @default(1.0)
  description         String?
  googleReviewUrl     String?
  referralBonusPoints Int      @default(50)
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  user               User                @relation(fields: [userId], references: [id])
  loyaltyCards       LoyaltyCard[]
  scanEvents         ScanEvent[]
  notifications      PushNotification[]
  emailNotifications EmailNotification[]
  rewards            Reward[]
  promotions         Promotion[]
}

model Customer {
  id        String   @id @default(cuid())
  userId    String   @unique
  firstName String
  lastName  String
  phone     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user         User               @relation(fields: [userId], references: [id])
  loyaltyCards LoyaltyCard[]
  pushSubs     PushSubscription[]
}

model LoyaltyCard {
  id                String   @id @default(cuid())
  businessId        String
  customerId        String
  serialNumber      String   @unique @default(cuid())
  stampCount        Int      @default(0)
  totalStamps       Int      @default(0)
  points            Int      @default(0)
  totalPointsEarned Int      @default(0)
  isActive          Boolean  @default(true)
  issuedAt          DateTime @default(now())
  updatedAt         DateTime @updatedAt

  business     Business      @relation(fields: [businessId], references: [id])
  customer     Customer      @relation(fields: [customerId], references: [id])
  transactions Transaction[]
  scanEvents   ScanEvent[]

  @@unique([businessId, customerId])
}

model Transaction {
  id          String   @id @default(cuid())
  cardId      String
  type        String
  stampsDelta Int      @default(1)
  pointsDelta Int      @default(0)
  amount      Float?
  note        String?
  createdAt   DateTime @default(now())

  card LoyaltyCard @relation(fields: [cardId], references: [id])
}

model ScanEvent {
  id           String   @id @default(cuid())
  businessId   String
  cardId       String
  amount       Float?
  pointsEarned Int      @default(0)
  scannedAt    DateTime @default(now())

  business Business    @relation(fields: [businessId], references: [id])
  card     LoyaltyCard @relation(fields: [cardId], references: [id])
}

model Reward {
  id             String   @id @default(cuid())
  businessId     String
  name           String
  description    String?
  pointsRequired Int
  isActive       Boolean  @default(true)
  createdAt      DateTime @default(now())

  business Business @relation(fields: [businessId], references: [id])
}

model PushSubscription {
  id         String   @id @default(cuid())
  customerId String
  endpoint   String   @unique
  p256dh     String
  auth       String
  platform   String?
  createdAt  DateTime @default(now())

  customer Customer @relation(fields: [customerId], references: [id])
}

model PushNotification {
  id         String   @id @default(cuid())
  businessId String
  title      String
  body       String
  sentAt     DateTime @default(now())
  status     String   @default("PENDING")
  sentCount  Int      @default(0)

  business Business @relation(fields: [businessId], references: [id])
}

model EmailNotification {
  id         String   @id @default(cuid())
  businessId String
  subject    String
  body       String
  sentAt     DateTime @default(now())
  sentCount  Int      @default(0)
  status     String   @default("SENT")

  business Business @relation(fields: [businessId], references: [id])
}

model PasswordResetToken {
  id        String   @id @default(cuid())
  email     String
  token     String   @unique
  expires   DateTime
  used      Boolean  @default(false)
  createdAt DateTime @default(now())
}

model Promotion {
  id         String   @id @default(cuid())
  businessId String
  name       String
  multiplier Float    @default(2.0)
  startDate  DateTime
  endDate    DateTime
  isActive   Boolean  @default(true)
  createdAt  DateTime @default(now())

  business Business @relation(fields: [businessId], references: [id])
}
